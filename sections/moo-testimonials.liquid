<section class="testimonials-section" id="testimonials">
  <div class="container mx-auto px-6 mb-12">
    <span class="text-[10px] text-moo-goldDim tracking-[0.3em] uppercase font-light">Testimonials</span>
    <h2 class="font-serif text-4xl lg:text-5xl text-moo-cream mt-3">Crunch Reviews</h2>
  </div>
  <div class="testimonial-track" id="testimonialTrack">
    {% for repeat in (1..2) %}
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-quote">{{ block.settings.quote }}</div>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm" style="background: linear-gradient(135deg, {{ block.settings.color_start }}, {{ block.settings.color_end }});">{{ block.settings.initials }}</div>
            <div>
              <div class="text-sm font-semibold text-moo-cream">{{ block.settings.name }}</div>
              <div class="text-xs text-moo-mute">{{ block.settings.role }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "MOO Testimonials",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "quote",
      "name": "Quote",
      "settings": [
        { "type": "text", "id": "initials", "label": "Initials", "default": "L" },
        { "type": "text", "id": "name", "label": "Name", "default": "Li Ming" },
        { "type": "text", "id": "role", "label": "Role", "default": "Fitness Coach - Beijing" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "This is the snack I look forward to most after training. Huge protein, insanely crisp, and easy to finish fast." },
        { "type": "color", "id": "color_start", "label": "Avatar gradient start", "default": "#c9a227" },
        { "type": "color", "id": "color_end", "label": "Avatar gradient end", "default": "#8a7020" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MOO Testimonials",
      "blocks": [
        { "type": "quote", "settings": { "initials": "L", "name": "Li Ming", "role": "Fitness Coach - Beijing", "quote": "This is the snack I look forward to most after training. Huge protein, insanely crisp, and easy to finish fast. I've already reordered it six times.", "color_start": "#c9a227", "color_end": "#8a7020" } },
        { "type": "quote", "settings": { "initials": "S", "name": "Sarah Chen", "role": "Product Manager - Shanghai", "quote": "The spicy version tastes real, not like fake industrial heat. It is aromatic first, then the crunch lands.", "color_start": "#db2777", "color_end": "#be123c" } },
        { "type": "quote", "settings": { "initials": "W", "name": "Wang Tao", "role": "Software Engineer - Shenzhen", "quote": "One bag around 3 or 4 p.m. kills the craving without the guilt. The peppery notes with coffee are ridiculously good.", "color_start": "#2563eb", "color_end": "#4338ca" } },
        { "type": "quote", "settings": { "initials": "Z", "name": "Zhang Wei", "role": "Food Creator - Chengdu", "quote": "As someone from Sichuan, I approve of this spicy cut. The numb kick of peppercorn and the aroma of chili are balanced really well.", "color_start": "#dc2626", "color_end": "#c2410c" } }
      ]
    }
  ]
}
{% endschema %}
