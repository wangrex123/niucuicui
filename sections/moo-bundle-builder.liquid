{{ 'moo-bundle-builder.css' | asset_url | stylesheet_tag }}
<script src="{{ 'moo-bundle-builder.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign builder_heading = section.settings.heading | default: page.title | default: 'Build your bundle'
  assign builder_intro = section.settings.intro
  assign bundle_cta = section.settings.button_label | default: 'Add selected to cart'
  assign builder_note = section.settings.note
  assign fallback_holy = all_products['moo-steak-chips-holy-heat']
  assign fallback_honey = all_products['moo-steak-chips-honey-blaze']
  assign rendered_count = 0
  assign holy_rendered = false
  assign honey_rendered = false
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  class="moo-bundle section-{{ section.id }}-padding"
  data-moo-bundle-builder
  data-bundle-min="2"
  data-bundle-discount-rate="0.10"
>
  <div class="page-width moo-bundle__page">
    <div class="moo-bundle__hero">
      {% if section.settings.eyebrow != blank %}
        <p class="moo-bundle__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="moo-bundle__heading">{{ builder_heading }}</h1>
      {% if builder_intro != blank %}
        <div class="moo-bundle__intro rte">{{ builder_intro }}</div>
      {% endif %}
    </div>

    <div class="moo-bundle__layout">
      <div class="moo-bundle__items-column">
        <div class="moo-bundle__presets" aria-label="Bundle presets">
          <button type="button" class="moo-bundle__preset" data-bundle-preset data-holy-qty="1" data-honey-qty="1">Variety 2-Pack</button>
          <button type="button" class="moo-bundle__preset" data-bundle-preset data-holy-qty="2" data-honey-qty="0">Holy Heat 2-Pack</button>
          <button type="button" class="moo-bundle__preset" data-bundle-preset data-holy-qty="0" data-honey-qty="2">Honey Blaze 2-Pack</button>
          <button type="button" class="moo-bundle__preset" data-bundle-preset data-holy-qty="2" data-honey-qty="2">Stock Up 4-Pack</button>
        </div>

        <div class="moo-bundle__items">
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% if block.settings.product != blank %}
                {% render 'moo-bundle-product-card',
                  product: block.settings.product,
                  badge: block.settings.badge,
                  description: block.settings.description,
                  default_quantity: block.settings.default_quantity,
                  block_attributes: block.shopify_attributes
                %}
                {% assign rendered_count = rendered_count | plus: 1 %}
                {% if block.settings.product.handle == 'moo-steak-chips-holy-heat' %}
                  {% assign holy_rendered = true %}
                {% elsif block.settings.product.handle == 'moo-steak-chips-honey-blaze' %}
                  {% assign honey_rendered = true %}
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}

          {% if holy_rendered == false and section.settings.holy_heat_product != blank %}
            {% render 'moo-bundle-product-card',
              product: section.settings.holy_heat_product,
              badge: 'Bold pepper expression',
              description: 'Brighter chili strike, louder crunch, and a fast savory finish.',
              default_quantity: 0
            %}
            {% assign rendered_count = rendered_count | plus: 1 %}
            {% assign holy_rendered = true %}
          {% endif %}

          {% if honey_rendered == false and section.settings.honey_blaze_product != blank %}
            {% render 'moo-bundle-product-card',
              product: section.settings.honey_blaze_product,
              badge: 'Warm amber finish',
              description: 'Warmer chili glow, smoother heat, and a sweeter everyday finish.',
              default_quantity: 0
            %}
            {% assign rendered_count = rendered_count | plus: 1 %}
            {% assign honey_rendered = true %}
          {% endif %}

          {% if holy_rendered == false and fallback_holy != blank %}
            {% render 'moo-bundle-product-card',
              product: fallback_holy,
              badge: 'Bold pepper expression',
              description: 'Brighter chili strike, louder crunch, and a fast savory finish.',
              default_quantity: 0
            %}
            {% assign rendered_count = rendered_count | plus: 1 %}
            {% assign holy_rendered = true %}
          {% endif %}

          {% if honey_rendered == false and fallback_honey != blank %}
            {% render 'moo-bundle-product-card',
              product: fallback_honey,
              badge: 'Warm amber finish',
              description: 'Warmer chili glow, smoother heat, and a sweeter everyday finish.',
              default_quantity: 0
            %}
            {% assign rendered_count = rendered_count | plus: 1 %}
            {% assign honey_rendered = true %}
          {% endif %}

          {% if rendered_count == 0 %}
            <div class="moo-bundle__empty">
              <h2>Bundle products are unavailable right now.</h2>
              <p>Reconnect Holy Heat and Honey Blaze in the theme editor if the products are not yet published.</p>
            </div>
          {% endif %}
        </div>
      </div>

      <aside class="moo-bundle-summary" data-bundle-summary>
        <div class="moo-bundle-summary__card">
          <p class="moo-bundle-summary__eyebrow">Bundle summary</p>
          <h2 class="moo-bundle-summary__title">{{ section.settings.summary_heading }}</h2>
          {% if builder_note != blank %}
            <p class="moo-bundle-summary__note">{{ builder_note }}</p>
          {% endif %}

          <div class="moo-bundle-summary__totals">
            <div class="moo-bundle-summary__row">
              <span>Selected items</span>
              <strong data-bundle-count>0</strong>
            </div>
            <div class="moo-bundle-summary__row">
              <span>Subtotal</span>
              <strong data-bundle-subtotal>{{ 0 | money }}</strong>
            </div>
            <div class="moo-bundle-summary__row moo-bundle-summary__row--savings">
              <span>Estimated 10% savings</span>
              <strong data-bundle-savings>{{ 0 | money }}</strong>
            </div>
            <div class="moo-bundle-summary__row moo-bundle-summary__row--total">
              <span>Estimated total</span>
              <strong data-bundle-total>{{ 0 | money }}</strong>
            </div>
          </div>

          <p class="moo-bundle-summary__unlock" data-bundle-unlock>
            Select products to build your bundle.
          </p>

          <div class="moo-bundle-summary__selected" data-bundle-selected-list>
            <p class="moo-bundle-summary__selected-empty">Select products to build your bundle.</p>
          </div>

          <button type="button" class="button button--primary moo-bundle-summary__button" data-bundle-submit {% if rendered_count == 0 %}disabled{% endif %}>
            <span data-bundle-submit-label>{{ bundle_cta }}</span>
          </button>

          <p class="moo-bundle-summary__status" data-bundle-status hidden></p>
        </div>
      </aside>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MOO Bundle Builder",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Build your bundle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your M\u014c\u014c lineup"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Mix Holy Heat and Honey Blaze into one cart-ready bundle. Select at least two bags, fine-tune each quantity, and add everything together in one click.</p>"
    },
    {
      "type": "product",
      "id": "holy_heat_product",
      "label": "Holy Heat product"
    },
    {
      "type": "product",
      "id": "honey_blaze_product",
      "label": "Honey Blaze product"
    },
    {
      "type": "text",
      "id": "summary_heading",
      "label": "Summary heading",
      "default": "Your custom bundle"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Summary note",
      "default": "Bundle totals update live as you select products. The 10% savings shown here is an estimate - your automatic Shopify discount will apply in cart or checkout once it is configured."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Add selected to cart"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Bundle product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Signature pick"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description"
        },
        {
          "type": "range",
          "id": "default_quantity",
          "min": 0,
          "max": 12,
          "step": 1,
          "label": "Default quantity",
          "default": 0
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "MOO Bundle Builder"
    }
  ]
}
{% endschema %}