{{ 'moo-bundle-builder.css' | asset_url | stylesheet_tag }}
<script src="{{ 'moo-bundle-builder.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign builder_heading = section.settings.heading | default: page.title | default: 'Build your bundle'
  assign builder_intro = section.settings.intro
  assign bundle_cta = section.settings.button_label | default: 'Add selected to cart'
  assign builder_note = section.settings.note
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="moo-bundle section-{{ section.id }}-padding" data-moo-bundle-builder>
  <div class="page-width moo-bundle__page">
    <div class="moo-bundle__hero">
      {% if section.settings.eyebrow != blank %}
        <p class="moo-bundle__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="moo-bundle__heading">{{ builder_heading }}</h1>
      {% if builder_intro != blank %}
        <div class="moo-bundle__intro rte">{{ builder_intro }}</div>
      {% endif %}
    </div>

    <div class="moo-bundle__layout">
      <div class="moo-bundle__items">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            {% liquid
              assign bundle_product = block.settings.product
              assign current_variant = bundle_product.selected_or_first_available_variant
              assign bundle_title = block.settings.title_override | default: bundle_product.title | default: 'Select a product'
              assign bundle_description = block.settings.description | default: bundle_product.description | strip_html | truncatewords: 22
              assign bundle_badge = block.settings.badge
              assign pack_copy = '4 OZ / 100G BAG'
              if bundle_product != blank and bundle_product.metafields.custom.pack_size.value != blank
                assign pack_copy = bundle_product.metafields.custom.pack_size.value
              endif
              assign default_qty = block.settings.default_quantity | default: 1
              if default_qty < 1
                assign default_qty = 1
              endif
              assign is_checked = block.settings.default_checked
              assign media = bundle_product.featured_media
            %}
            <article
              class="moo-bundle-card{% if bundle_product == blank %} is-disabled{% endif %}"
              {{ block.shopify_attributes }}
              data-bundle-item
              {% if current_variant != blank %}
                data-variant-id="{{ current_variant.id }}"
                data-price="{{ current_variant.price }}"
                data-product-title="{{ bundle_title | escape }}"
                data-product-url="{{ bundle_product.url }}"
                data-available="{% if current_variant.available %}true{% else %}false{% endif %}"
              {% endif %}
            >
              <div class="moo-bundle-card__select">
                <label class="moo-bundle-card__checkbox-label">
                  <input
                    type="checkbox"
                    class="moo-bundle-card__checkbox"
                    data-bundle-toggle
                    {% if is_checked %}checked{% endif %}
                    {% if bundle_product == blank or current_variant == blank or current_variant.available == false %}disabled{% endif %}
                  >
                  <span class="moo-bundle-card__checkbox-ui"></span>
                </label>
              </div>

              <div class="moo-bundle-card__content">
                <div class="moo-bundle-card__media">
                  {% if media != blank %}
                    <img
                      src="{{ media.preview_image | image_url: width: 900 }}"
                      alt="{{ media.alt | default: bundle_title | escape }}"
                      class="moo-bundle-card__image"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="moo-bundle-card__placeholder">
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {% endif %}
                </div>

                <div class="moo-bundle-card__body">
                  <div class="moo-bundle-card__meta">
                    {% if bundle_badge != blank %}
                      <span class="moo-bundle-card__badge">{{ bundle_badge }}</span>
                    {% endif %}
                    {% if bundle_product != blank %}
                      <a href="{{ bundle_product.url }}" class="moo-bundle-card__title-link">
                        <h2 class="moo-bundle-card__title">{{ bundle_title }}</h2>
                      </a>
                    {% else %}
                      <h2 class="moo-bundle-card__title">{{ bundle_title }}</h2>
                    {% endif %}
                    {% if bundle_description != blank %}
                      <p class="moo-bundle-card__description">{{ bundle_description }}</p>
                    {% endif %}
                  </div>

                  <div class="moo-bundle-card__footer">
                    <div class="moo-bundle-card__price-group">
                      <span class="moo-bundle-card__price">
                        {% if current_variant != blank %}
                          {{ current_variant.price | money }}
                        {% else %}
                          Select product
                        {% endif %}
                      </span>
                      <span class="moo-bundle-card__pack">{{ pack_copy | upcase }}</span>
                    </div>

                    <div class="moo-bundle-card__actions">
                      <div class="moo-bundle-qty" data-bundle-qty>
                        <button type="button" class="moo-bundle-qty__button" data-bundle-decrease aria-label="Decrease quantity" {% if bundle_product == blank or current_variant == blank or current_variant.available == false %}disabled{% endif %}>-</button>
                        <input
                          type="number"
                          min="1"
                          step="1"
                          value="{{ default_qty }}"
                          class="moo-bundle-qty__input"
                          data-bundle-quantity
                          {% if bundle_product == blank or current_variant == blank or current_variant.available == false %}disabled{% endif %}
                        >
                        <button type="button" class="moo-bundle-qty__button" data-bundle-increase aria-label="Increase quantity" {% if bundle_product == blank or current_variant == blank or current_variant.available == false %}disabled{% endif %}>+</button>
                      </div>

                      {% if bundle_product != blank %}
                        <a href="{{ bundle_product.url }}" class="moo-bundle-card__link">View product</a>
                      {% else %}
                        <span class="moo-bundle-card__link is-disabled">Choose product in editor</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            </article>
          {% endfor %}
        {% else %}
          <div class="moo-bundle__empty">
            <h2>Add bundle products in the theme editor</h2>
            <p>Use section blocks to connect the products you want available on the bundle page.</p>
          </div>
        {% endif %}
      </div>

      <aside class="moo-bundle-summary" data-bundle-summary>
        <div class="moo-bundle-summary__card">
          <p class="moo-bundle-summary__eyebrow">Bundle summary</p>
          <h2 class="moo-bundle-summary__title">{{ section.settings.summary_heading }}</h2>
          {% if builder_note != blank %}
            <p class="moo-bundle-summary__note">{{ builder_note }}</p>
          {% endif %}

          <div class="moo-bundle-summary__totals">
            <div class="moo-bundle-summary__row">
              <span>Selected items</span>
              <strong data-bundle-count>0</strong>
            </div>
            <div class="moo-bundle-summary__row moo-bundle-summary__row--total">
              <span>Estimated total</span>
              <strong data-bundle-total>{{ 0 | money }}</strong>
            </div>
          </div>

          <div class="moo-bundle-summary__selected" data-bundle-selected-list>
            <p class="moo-bundle-summary__selected-empty">Select products to build your bundle.</p>
          </div>

          <button type="button" class="button button--primary moo-bundle-summary__button" data-bundle-submit {% if section.blocks.size == 0 %}disabled{% endif %}>
            <span data-bundle-submit-label>{{ bundle_cta }}</span>
          </button>

          <p class="moo-bundle-summary__status" data-bundle-status hidden></p>
        </div>
      </aside>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MOO Bundle Builder",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Build your bundle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose your M\u014c\u014c lineup"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Mix Holy Heat and Honey Blaze into one cart-ready bundle. Select the bags you want, set your quantities, and add them together in one click.</p>"
    },
    {
      "type": "text",
      "id": "summary_heading",
      "label": "Summary heading",
      "default": "Your custom bundle"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Summary note",
      "default": "Bundle totals update live as you select products. Use the quantity controls to fine-tune your order before adding everything to cart."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Add selected to cart"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Bundle product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Signature pick"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Title override"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short description"
        },
        {
          "type": "checkbox",
          "id": "default_checked",
          "label": "Selected by default",
          "default": true
        },
        {
          "type": "range",
          "id": "default_quantity",
          "min": 1,
          "max": 12,
          "step": 1,
          "label": "Default quantity",
          "default": 1
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "MOO Bundle Builder",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}
