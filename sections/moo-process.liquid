<!-- Process Timeline -->
  <section class="process-section" id="process">
    <div class="process-sticky">
      <!-- Background Images (replace background: CSS with real images) -->
      <div class="process-bg" id="bg1">
        <img src="{{ 'moo-process-bg1.png' | asset_url }}" alt="" class="process-bg-image" decoding="async">
      </div>
      <div class="process-bg" id="bg2">
        <img src="{{ 'moo-process-bg2.png' | asset_url }}" alt="" class="process-bg-image" decoding="async">
      </div>
      <div class="process-bg" id="bg3">
        <img src="{{ 'moo-process-bg3.png' | asset_url }}" alt="" class="process-bg-image" decoding="async">
      </div>
      <div class="process-bg" id="bg4">
        <img src="{{ 'moo-process-bg4.png' | asset_url }}" alt="" class="process-bg-image" decoding="async">
      </div>

      <div class="absolute top-12 left-1/2 -translate-x-1/2 text-center z-20">
        <span class="text-[10px] text-moo-goldDim tracking-[0.3em] uppercase font-light">Process</span>
        <h2 class="font-serif text-4xl lg:text-5xl text-moo-cream mt-3">72 Hours to Crisp</h2>
      </div>

      <div class="process-line z-20"><div class="process-line-fill" id="processLineFill"></div></div>

      <div class="process-step z-20" id="step1" style="top: 22%;"><div class="process-dot"></div><div class="process-step-num">STEP 01</div><div class="process-step-title">Source</div><div class="process-step-desc">Grass-fed beef hind leg<br>Hand-trimmed and cleaned</div></div>
      <div class="process-step z-20" id="step2" style="top: 42%;"><div class="process-dot"></div><div class="process-step-num">STEP 02</div><div class="process-step-title">Slice</div><div class="process-step-desc">Cut precisely to 2mm<br>For even heat all through</div></div>
      <div class="process-step z-20" id="step3" style="top: 62%;"><div class="process-dot"></div><div class="process-step-num">STEP 03</div><div class="process-step-title">Crisp</div><div class="process-step-desc">72 hours of low-temp drying<br>For a honeycomb fiber crunch</div></div>
      <div class="process-step z-20" id="step4" style="top: 82%;"><div class="process-dot"></div><div class="process-step-num">STEP 04</div><div class="process-step-title">Seal Fresh</div><div class="process-step-desc">Nitrogen-flushed pack<br>Cold-chain ready delivery</div></div>
    </div>
  </section>

  

