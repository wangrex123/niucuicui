<section class="cta-section" id="cta">
  <div class="container mx-auto px-6 text-center">
    <span class="text-[10px] text-moo-goldDim tracking-[0.3em] uppercase font-light block mb-8">Join the Club</span>
    <h2 class="font-serif text-5xl lg:text-7xl text-moo-cream mb-8">Ready for your next crunch?</h2>
    <p class="text-moo-mute max-w-lg mx-auto mb-12 text-lg font-light leading-relaxed">Join the MOO list for 20% off your first order and first access to limited flavor drops.</p>
    {% form 'customer', class: 'max-w-lg mx-auto flex flex-col sm:flex-row gap-4' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="your@email.com" required class="flex-1 px-8 py-5 bg-moo-surface border border-moo-border rounded-full text-moo-cream placeholder-moo-mute focus:outline-none focus:border-moo-gold transition-all text-sm">
      <button type="submit" class="btn-primary mt-0">Join Now</button>
      {% if form.posted_successfully? %}
        <p class="moo-newsletter-status w-full">Welcome in. Your first-update email is on the way.</p>
      {% endif %}
      {% if form.errors %}
        <div class="moo-newsletter-errors w-full">{{ form.errors | default_errors }}</div>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "MOO CTA",
  "settings": [],
  "presets": [
    {
      "name": "MOO CTA"
    }
  ]
}
{% endschema %}
