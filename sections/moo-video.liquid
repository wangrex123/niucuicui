<section class="video-section" id="video">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-[10px] text-moo-goldDim tracking-[0.3em] uppercase font-light">Behind the Scenes</span>
      <h2 class="font-serif text-4xl lg:text-5xl text-moo-cream mt-3">See the Crunch</h2>
    </div>
    <div class="video-container">
      <button type="button" class="video-poster" id="videoPoster" data-moo-video-trigger aria-label="Play video">
        <span class="play-btn"><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></span>
      </button>
      <video id="mainVideo" class="w-full h-full object-cover" playsinline muted loop controls>
        {% if section.settings.video_url != blank %}
          <source src="{{ section.settings.video_url | escape }}" type="video/mp4">
        {% endif %}
      </video>
    </div>
    <p class="text-center text-moo-mute text-sm mt-6">{{ section.settings.caption }}</p>
  </div>
</section>

{% schema %}
{
  "name": "MOO Video",
  "settings": [
    {
      "type": "url",
      "id": "video_url",
      "label": "MP4 URL"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "Replace this placeholder with your hosted brand video when ready."
    }
  ],
  "presets": [
    {
      "name": "MOO Video"
    }
  ]
}
{% endschema %}
