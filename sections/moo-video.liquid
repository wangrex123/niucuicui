<section class="video-section" id="video">
  <div class="container mx-auto px-6">
    <div class="video-section__header text-center mb-16">
      <span class="video-section__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="video-section__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="video-section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="video-container">
      <video
        id="mainVideo"
        class="video-section__video w-full h-full object-cover"
        playsinline
        controls
        preload="metadata"
      >
        {% if section.settings.video_url != blank %}
          <source src="{{ section.settings.video_url | escape }}" type="video/mp4">
        {% endif %}
      </video>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MOO Video",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "M\u014c\u014c Brand Film"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for the Bold."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real steak. Big crunch. Crafted for those who earn it."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "MP4 URL"
    }
  ],
  "presets": [
    {
      "name": "MOO Video"
    }
  ]
}
{% endschema %}
